# Ignore everything without an extension, then selectively allow files and directories.
*
!*.*
!*/

# Don't ignore makefiles and license files.
!makefile
!Makefile
!LICENSE

# Ignore build artifacts.
*.o
*.a
*.hex
*.elf

# Ignore simulated EEPROM images written by the simavr harness.
eeprom.bin

# Ignore IDE directories.
.vscode/
.vs/
.claude/

# Ignore temp/ directory.
temp/
